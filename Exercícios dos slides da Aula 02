// MATRIZ TRANSPOSTA 

#include <stdio.h>

int main() {
    int A[6][6], B[6][6];
    int i, j;

    for(i = 0; i < 6; i++) {
        for(j = 0; j < 6; j++) {
            printf("Posicao [%d][%d]: ", i, j);
            scanf("%d", &A[i][j]);
        }
    }

    for(i = 0; i < 6; i++) {
        for(j = 0; j < 6; j++) {
            B[j][i] = A[i][j];
        }
    }

    printf("\nMatriz transposta:\n ");
    for(i = 0; i < 6; i++) {
        for(j = 0; j < 6; j++) {
            printf("%d ", B[i][j]);
        }
        printf("\n");
    }

    return 0;
}
