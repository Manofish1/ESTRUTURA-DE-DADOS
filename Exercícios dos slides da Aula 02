//VETOR INVERTIDO
#include <stdio.h>

int main()
{
    int vet[5];
    int i;
    //ordem normal
    for(i = 0; i < 5; i++) {
        printf("digite o valor da poicao %d : ", i);
        scanf("%d", &vet[i]);
    }
    //orden invertida
    for(i = 4; i >= 0; i--)
        printf("%d", vet[i]);
    
    return 0;
}

