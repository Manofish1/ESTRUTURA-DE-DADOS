//VETOR DOBRADO
#include <stdio.h>

int main()
{
    int vetN[10]; // N=normal
    int vetD[10]; // D=dobrado
    int i;
    for(i = 0; i < 10; i++) {
        printf("digite o valor da poicao %d : ", i);
        scanf("%d", &vetN[i]);
        
        vetD[i] = vetN[i] * 2; //coloquei 10 no lugar do i e deu erro
    }
   printf("\noriginal | dobrado\n");
   printf("-----------|-----------\n");
    for(i = 0; i < 10; i++) {
        printf("%-10d |  %d\n", vetN[i], vetD[i]);
// O %-10d alinha o número à esquerda com 10 espaços de reserva
    }
    return 0;
}

