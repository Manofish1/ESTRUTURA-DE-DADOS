//VETORES
#include <stdio.h>

int main() {
   int A[10], B[10];
   int i;
   
   for(i = 0; i<10; i++) {
      printf("%d- digite os dados para o vetor A: ", i); 
       scanf("%d", &A[i]);
   }
   printf("saida de dados do vetor A: \n");
    for(i = 0; i<10; i++) {
      printf("A[%d] = %d: \n ", i, A[i]); 
   }
   
   printf("saida de dados do vetor B: \n");
    for(i = 0; i<10; i++){
        B[i] = A[i] *10;
        printf("B[%d] = %d: \n ",i, B[i]);
    }
   
    return 0;
}

