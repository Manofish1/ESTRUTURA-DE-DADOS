//Média de Notas

#include <stdio.h>

int main() {
   float notas[4];
   int i;
   float soma = 0;
   float media;
   
   for(i = 0; i<4; i++) {
      printf("informe sua primeira nota: "); 
       scanf("%f", &notas[i]);
       soma = soma + notas[i];
       
   }
   media = soma / 4; 
   printf("a sua media e: = %.2f \n ",media);
    return 0;
}
